{
  "manifest_version": 3,
  "name": "LingQue Browser Relay",
  "version": "1.3.0",
  "description": "Connect local browser to LingQue Agent for remote control",
  "permissions": ["debugger", "tabs", "activeTab", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LingQue Browser Relay"
  },
  "host_permissions": ["<all_urls>"]
}
